generator client {
    provider = "prisma-client"
}

datasource db {
    provider = "sqlite"
}

model Ticket {
    id        Int      @id @default(autoincrement())
    channelId String   @unique
    guildId   String
    userId    String
    status    String   @default("OPEN") // Values: OPEN, CLOSED
    createdAt DateTime @default(now())
}

model VerifiedUser {
    id        Int      @id @default(autoincrement())
    userId    String
    guildId   String
    createdAt DateTime @default(now())

    @@unique([userId, guildId]) // Prevents duplicate entries
}

model UserWarn {
    userId    String
    guildId   String
    warnCount Int      @default(0)
    updatedAt DateTime @updatedAt

    @@id([userId, guildId])
}
