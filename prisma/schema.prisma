generator client {
    provider = "prisma-client"
}

datasource db {
    provider = "sqlite"
}

model Ticket {
    id        Int      @id @default(autoincrement())
    channelId String   @unique
    guildId   String
    userId    String
    status    String   @default("OPEN") // Values: OPEN, CLOSED
    createdAt DateTime @default(now())
}

model VerifiedUser {
    id        Int      @id @default(autoincrement())
    userId    String
    guildId   String
    createdAt DateTime @default(now())

    @@unique([userId, guildId]) // Prevents duplicate entries
}

model UserWarn {
    userId    String
    guildId   String
    warnCount Int      @default(0)
    updatedAt DateTime @updatedAt

    @@id([userId, guildId])
}

model StickyRole {
    id        Int      @id @default(autoincrement())
    userId    String
    guildId   String
    roleIds   String // Stores role IDs separated by commas (e.g., "123,456,789")
    updatedAt DateTime @updatedAt

    @@unique([userId, guildId]) // Prevents duplicate rows for the same user in the same server
}
